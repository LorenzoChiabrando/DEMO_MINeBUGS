# ==========================================
# MINeBUGS Environment Configuration
# ==========================================

# --- PROJECT SETTINGS ---
COMPOSE_PROJECT_NAME=minebugs-project
NODE_ENV=production

# --- PORTS (Host Mapping) ---
PORT_HTTP=80
PORT_DB_DEBUG=5433
PORT_RABBIT_MGMT=15672

# --- POSTGRESQL DATABASE ---
POSTGRES_DB=minebugs
POSTGRES_USER=admin_minebugs
POSTGRES_PASSWORD=secret_password_change_me_in_prod
# Nota: POSTGRES_HOST non serve qui, è interno a Docker (usa il nome servizio 'db')

# --- RABBITMQ BROKER ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
# Configurazione Code e Routing
RABBITMQ_QUEUE_MAPPING=taxa_mapping_queue
RABBITMQ_EXCHANGE=minebugs_exchange
RABBITMQ_ROUTING_MAPPING=key_taxa_mapping
RABBITMQ_QUEUE_SIMULATION=queue_simulation
RABBITMQ_ROUTING_SIMULATION=key_simulation

# --- MINIO STORAGE ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret_password
MINIO_BUCKET=minebugs-data
# Endpoint interno per i servizi
MINIO_ENDPOINT=minebugs-minio:9000
MINIO_BUCKET_REF=reference-data
AGORA_ZIP_KEY=agora2_seed.zip

# --- WORKERS CONFIG ---
APP_WORKER_TOKEN=token_worker_interno
# URL che il worker usa per contattare Spring Boot
BACKEND_BASE_URL=http://minebugs-backend:8080

WORK_DIR_BASE=/app/temp_work
AGORA_MODELS_PATH=/app/data/agora_models
# Path dove il Dockerfile ha messo l'eseguibile C++
SOLVER_BINARY_PATH=/app/solver_bin/solver_cpp

# --- BACKEND CONFIG ---
SPRING_PROFILE=prod